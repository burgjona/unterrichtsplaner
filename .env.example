# Kopie als .env anlegen; .env NIEMALS committen (steht in .gitignore).
# Alle Werte haben Defaults in src/config.py – hier nur Overrides.

# SQLite-Datei (Default: ./data.db)
DB_PATH=./data.db

# NAS-Ablagebaum (Default: ./storage). Auf der Synology der gemountete Freigabepfad.
STORAGE_ROOT=./storage

# Temporärer Upload-Ordner für atomaren rename() (Default: ./uploads)
UPLOAD_TMP=./uploads

# Lehrplan-MD-Dateien für den Lernbereich-Seed (Default: ./docs)
DOCS_DIR=./docs

# --- Auth / Sessions (Meilenstein 2) ---
# Server-Master-Key (base64, 32 Byte) zum Verschlüsseln des nutzereigenen Anthropic-Keys (AES-256-GCM).
# Erzeugen mit:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
APP_SECRET_KEY=
# Session-Lebensdauer in Stunden (Default 168 = 7 Tage)
SESSION_TTL_HOURS=168
# Cookie nur über HTTPS senden: auf der Synology hinter Cloudflare auf 1 setzen (lokal 0)
COOKIE_SECURE=0
# Der Anthropic-API-Key selbst wird NICHT hier abgelegt, sondern verschlüsselt in SQLite.
